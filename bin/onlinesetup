#!/bin/bash

function git_init() {
    # $1 -- repository
    # $2 -- branch to checkout
    git init -qqq
    git remote add origin-install $1
    git fetch origin-install -qqq
    git checkout $2 -- src
    # TODO: add bin folder so it will be possible to use shell scripts during installation

    PREV_DOTGLOB=$(shopt -p | grep dotglob)
    shopt -s dotglob
    mv ./src/* ./
    $PREV_DOTGLOB
    rm -rf ./src
}

function makefile_init() {
    touch -a Makefile
    if [[ ! $(grep -qxF 'include ./.dockerizer/dockerizer.mk' Makefile) ]]; then
        echo 'include ./.dockerizer/dockerizer.mk' >> Makefile
    fi
}

REPO=${1:-https://github.com/OleksiiBulba/php-dockerizer}
VERSION=${2:-origin/master}
INSTALL_ROOT=${3:-./}
INSTALL_DIR='.dockerizer'
INSTALL_ROOT=$(realpath $INSTALL_ROOT)
CURRENT_DIR=$(pwd)
cd $INSTALL_ROOT; mkdir $INSTALL_DIR; cd ./$INSTALL_DIR
git_init $REPO $VERSION
cd $CURRENT_DIR
makefile_init
